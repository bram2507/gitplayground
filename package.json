{
  "name": "lit-hexagonal-practice",
  "version": "1.0.0",
  "description": "Proyecto LitElement con arquitectura hexagonal, SOLID, tests (unit/e2e/a11y) y Web Test Runner + Sinon",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "web-test-runner \"tests/unit/**/*.test.js\"",
    "test:e2e": "web-test-runner \"tests/e2e/**/*.test.js\"",
    "test:a11y": "web-test-runner \"tests/a11y/**/*.test.js\"",
    "test": "npm run test:unit && npm run test:e2e && npm run test:a11y"
  },
  "dependencies": {
    "lit": "^4.1.0",
    "@lit-labs/router": "^7.1.4"
  },
  "devDependencies": {
    "vite": "^7.2.14",
    "@web/test-runner": "^7.14.0",
    "@web/test-runner-playwright": "^7.10.0",
    "@open-wc/testing": "^7.2.0",
    "@open-wc/testing-helpers": "^7.2.1",
    "chai": "^7.1.0",
    "sinon": "^17.0.1",
    "axe-core": "^7.8.1"
  }
}